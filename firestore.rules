rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Helpers ---
    function isValidUserProfile(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid == request.auth.uid &&
             data.email is string &&
             (!data.keys().contains('taxRate') || data.taxRate is number);
    }

    function isValidContentPiece(data) {
      return data.keys().hasAll(['userId', 'idea', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.idea is string && data.idea.size() <= 5000 &&
             data.createdAt is timestamp;
    }

    function isValidExpense(data) {
      return data.keys().hasAll(['userId', 'amount', 'category', 'date']) &&
             data.userId == request.auth.uid &&
             data.amount is number &&
             data.category is string &&
             data.date is timestamp;
    }

    function isValidBudget(data) {
      return data.keys().hasAll(['userId', 'month', 'limit']) &&
             data.userId == request.auth.uid &&
             data.month is string &&
             data.limit is number;
    }

    function isValidDailyLog(data) {
      return data.keys().hasAll(['userId', 'date']) &&
             data.userId == request.auth.uid &&
             data.date is string;
    }

    function isValidGoal(data) {
      return data.keys().hasAll(['gmvGoal', 'commissionGoal', 'videosTarget']) &&
             (!data.keys().contains('userId') || data.userId == request.auth.uid);
    }

    function isValidBrandDeal(data) {
      return data.keys().hasAll(['userId', 'brandName', 'fee']) &&
             data.userId == request.auth.uid;
    }

    function isValidWeeklyReview(data) {
      return data.keys().hasAll(['userId', 'timestamp']) &&
             data.userId == request.auth.uid;
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['userId', 'name']) &&
             data.userId == request.auth.uid &&
             data.name is string && data.name.size() <= 200;
    }

    function isValidScript(data) {
      return data.keys().hasAll(['userId', 'productId', 'content']) &&
             data.userId == request.auth.uid &&
             data.productId is string &&
             data.content is string && data.content.size() <= 10000;
    }

    // --- Collections ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUserProfile(incoming());
      allow update: if isOwner(userId) && isValidUserProfile(incoming()) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'taxRate', 'tiktokHandle', 'onboarded']);
    }

    match /goals/{userId} {
      allow get: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidGoal(incoming());
    }

    match /daily_logs/{logId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create, update: if isSignedIn() && incoming().userId == request.auth.uid && isValidDailyLog(incoming());
    }

    match /brand_deals/{dealId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create, update: if isSignedIn() && incoming().userId == request.auth.uid && isValidBrandDeal(incoming());
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /weekly_reviews/{reviewId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidWeeklyReview(incoming());
    }

    match /content/{contentId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidContentPiece(incoming());
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && isValidContentPiece(incoming());
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /expenses/{expenseId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidExpense(incoming());
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && isValidExpense(incoming());
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /budgets/{budgetId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidBudget(incoming());
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && isValidBudget(incoming());
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /products/{productId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidProduct(incoming());
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && isValidProduct(incoming());
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /scripts/{scriptId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidScript(incoming());
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && isValidScript(incoming());
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
